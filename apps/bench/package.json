    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "happy-dom": "20.9.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "4.1.6"
  }
}
